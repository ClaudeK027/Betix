# =============================================================================
# BETIX — Variables d'environnement Backend
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================================

# --- App ---
APP_NAME=BETIX API
APP_VERSION=0.1.0
DEBUG=true

# --- CORS ---
FRONTEND_URL=http://localhost:3000

# --- API-Sports (Football + Basketball) ---
# Inscription : https://dashboard.api-football.com/register
API_SPORTS_KEY=

# --- API-Tennis ---
# Inscription : https://api-tennis.com
API_TENNIS_KEY=

# --- Gemini (IA) ---
# Console : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Supabase ---
# Dashboard : https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Mollie ---
# Dashboard : https://my.mollie.com/dashboard
MOLLIE_API_KEY=
